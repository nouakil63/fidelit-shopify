# Injectées automatiquement par `shopify app dev`, à configurer sur l'hébergeur.
DATABASE_URL=postgresql://user:password@host:5432/database
DIRECT_URL=postgresql://user:password@host:5432/database
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://app.example.com
SCOPES=read_customers,read_orders,write_discounts,write_app_proxy

# Envoi des récompenses (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxx
REWARD_EMAIL_FROM=La boutique <fidelite@example.com>

# Production
NODE_ENV=production
PORT=3000
